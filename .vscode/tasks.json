{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build TempleRun",
      "type": "shell",
      "command": "make",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "Run TempleRun",
      "type": "shell",
      "command": "make",
      "args": ["run"],
      "dependsOn": "Build TempleRun",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
